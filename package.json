{
	"name": "obsidian-simple-templates-plugin",
	"version": "0.0.1",
	"description": "Insert reusable templates into Obsidian notes.",
	"main": "main.js",
	"scripts": {
		"dev": "vite build --mode=development --watch",
		"build": "vite build --mode=production",
		"typecheck": "tsc --noEmit --skipLibCheck",
		"test": "bun test",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint --max-warnings=0",
		"lint:fix": "eslint --max-warnings=0 --fix packages/**",
		"check": "bun run format:check && bun run typecheck && bun run lint && bun run test",
		"check:fix": "bun run format && bun run typecheck && bun run lint:fix && bun run test",
		"release": "lemons-automation release"
	},
	"keywords": [],
	"author": "Moritz Jung",
	"license": "GPL-3.0",
	"devDependencies": {
		"@lemons_dev/lemons-obsidian-plugin-automation": "^0.1.3",
		"@types/bun": "^1.3.14",
		"eslint": "^9.39.4",
		"eslint-plugin-no-relative-import-paths": "^1.6.1",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"obsidian": "latest",
		"prettier": "^3.8.3",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "8.59.3",
		"vite": "^8.0.16",
		"vite-plugin-banner": "^0.8.1",
		"vite-plugin-static-copy": "^4.1.0"
	},
	"dependencies": {
		"yaml": "^2.9.0"
	}
}
